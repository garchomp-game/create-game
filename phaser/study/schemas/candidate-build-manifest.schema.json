{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://arena-core.local/schemas/candidate-build-manifest.v1.json",
  "title": "Arena Core Frozen Candidate Build Manifest v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "studyId",
    "studyLogProtocolVersion",
    "humanProtocolVersion",
    "hypothesisId",
    "cellId",
    "arm",
    "sessionKind",
    "studyDefinitionPath",
    "studyDefinitionDigest",
    "expectedStepIds",
    "assignmentRule",
    "eligibility",
    "independentVariable",
    "diffAllowlist",
    "fixedVariables",
    "primaryMetric",
    "guardMetrics",
    "denominator",
    "minimumFormativeReach",
    "immediateStop",
    "adoptCriteria",
    "reviseCriteria",
    "rejectCriteria",
    "baseline",
    "candidate",
    "mergeBaseSha",
    "lockfileDigest",
    "configDigest",
    "requiredT3Lanes",
    "knownBlockedLanes"
  ],
  "properties": {
    "schemaVersion": {
      "const": "candidate-build-manifest.v1"
    },
    "studyId": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "studyLogProtocolVersion": {
      "type": "integer",
      "minimum": 1
    },
    "humanProtocolVersion": {
      "type": "integer",
      "minimum": 1
    },
    "hypothesisId": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "cellId": {
      "enum": [
        "T1.1",
        "T2-S1",
        "T2-S2",
        "T2-S3",
        "T1.2-C",
        "F-Audio",
        "F-Text",
        "F-Visual",
        "H-Timing",
        "H-Emphasis",
        "O1-MOVE",
        "O1-A",
        "O1-B",
        "C1-R",
        "C1-U",
        "C1-A",
        "C1-P",
        "X1",
        "F1-TITLE",
        "F1-MODE",
        "F1-HELP",
        "F1-RESULT",
        "CH1",
        "CH2",
        "CH3-S",
        "CH4-M"
      ]
    },
    "arm": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "sessionKind": {
      "enum": [
        "o1",
        "full-training",
        "context-prompt",
        "retention"
      ]
    },
    "studyDefinitionPath": {
      "type": "string",
      "minLength": 6,
      "maxLength": 256,
      "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$))[A-Za-z0-9._/-]+\\.json$"
    },
    "studyDefinitionDigest": {
      "$ref": "#/$defs/nonZeroDigest"
    },
    "expectedStepIds": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "type": "string",
        "minLength": 1,
        "maxLength": 128,
        "pattern": "^[A-Za-z0-9._:-]+$"
      }
    },
    "assignmentRule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "method",
        "occursBeforeOffer",
        "stickyWithinAssignment",
        "eligibilityRule"
      ],
      "properties": {
        "method": {
          "enum": [
            "manual-randomization",
            "deterministic-hash",
            "external-assignment",
            "not-applicable"
          ]
        },
        "occursBeforeOffer": {
          "type": "boolean"
        },
        "stickyWithinAssignment": {
          "type": "boolean"
        },
        "eligibilityRule": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    },
    "eligibility": {
      "$ref": "#/$defs/nonEmptyUniqueStrings"
    },
    "independentVariable": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "diffAllowlist": {
      "$ref": "#/$defs/nonEmptyUniqueStrings"
    },
    "fixedVariables": {
      "$ref": "#/$defs/nonEmptyUniqueStrings"
    },
    "primaryMetric": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "guardMetrics": {
      "$ref": "#/$defs/nonEmptyUniqueStrings"
    },
    "denominator": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "minimumFormativeReach": {
      "$ref": "#/$defs/nonEmptyString"
    },
    "immediateStop": {
      "$ref": "#/$defs/nonEmptyUniqueStrings"
    },
    "adoptCriteria": {
      "$ref": "#/$defs/nonEmptyUniqueStrings"
    },
    "reviseCriteria": {
      "$ref": "#/$defs/nonEmptyUniqueStrings"
    },
    "rejectCriteria": {
      "$ref": "#/$defs/nonEmptyUniqueStrings"
    },
    "baseline": {
      "$ref": "#/$defs/artifactIdentity"
    },
    "candidate": {
      "$ref": "#/$defs/artifactIdentity"
    },
    "mergeBaseSha": {
      "$ref": "#/$defs/nonZeroSha"
    },
    "lockfileDigest": {
      "$ref": "#/$defs/nonZeroDigest"
    },
    "configDigest": {
      "$ref": "#/$defs/nonZeroDigest"
    },
    "requiredT3Lanes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/t3Lane"
      }
    },
    "knownBlockedLanes": {
      "type": "array",
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/t3Lane"
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "cellId": {
            "enum": [
              "O1-A",
              "O1-B"
            ]
          }
        },
        "required": [
          "cellId"
        ]
      },
      "then": {
        "properties": {
          "assignmentRule": {
            "type": "object",
            "properties": {
              "method": {
                "enum": [
                  "manual-randomization",
                  "deterministic-hash",
                  "external-assignment"
                ]
              },
              "occursBeforeOffer": {
                "const": true
              },
              "stickyWithinAssignment": {
                "const": true
              }
            }
          },
          "sessionKind": {
            "const": "o1"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "cellId": {
            "const": "O1-A"
          }
        },
        "required": [
          "cellId"
        ]
      },
      "then": {
        "properties": {
          "arm": {
            "const": "A"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "cellId": {
            "const": "O1-B"
          }
        },
        "required": [
          "cellId"
        ]
      },
      "then": {
        "properties": {
          "arm": {
            "const": "B"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "sessionKind": {
            "enum": [
              "o1",
              "full-training"
            ]
          }
        },
        "required": [
          "sessionKind"
        ]
      },
      "then": {
        "properties": {
          "expectedStepIds": {
            "type": "array",
            "minItems": 1
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "sessionKind": {
            "enum": [
              "context-prompt",
              "retention"
            ]
          }
        },
        "required": [
          "sessionKind"
        ]
      },
      "then": {
        "properties": {
          "expectedStepIds": {
            "type": "array",
            "maxItems": 0
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "sessionKind": {
            "const": "full-training"
          }
        },
        "required": [
          "sessionKind"
        ]
      },
      "then": {
        "properties": {
          "expectedStepIds": {
            "type": "array",
            "minItems": 9,
            "maxItems": 9
          }
        }
      }
    }
  ],
  "$defs": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1,
      "maxLength": 512,
      "pattern": ".*\\S.*"
    },
    "nonEmptyUniqueStrings": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/nonEmptyString"
      }
    },
    "nonZeroSha": {
      "type": "string",
      "pattern": "^(?!0{40}$)[0-9a-f]{40}$"
    },
    "nonZeroDigest": {
      "type": "string",
      "pattern": "^sha256:(?!0{64}$)[0-9a-f]{64}$"
    },
    "artifactIdentity": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "headSha",
        "buildMarker",
        "artifactDigest",
        "appVersion",
        "rulesetVersion"
      ],
      "properties": {
        "headSha": {
          "$ref": "#/$defs/nonZeroSha"
        },
        "buildMarker": {
          "type": "string",
          "minLength": 7,
          "maxLength": 128,
          "pattern": "^(?!replace-me$).*\\S.*$"
        },
        "artifactDigest": {
          "$ref": "#/$defs/nonZeroDigest"
        },
        "appVersion": {
          "$ref": "#/$defs/nonEmptyString"
        },
        "rulesetVersion": {
          "$ref": "#/$defs/nonEmptyString"
        }
      }
    },
    "t3Lane": {
      "enum": [
        "e2e",
        "webgl",
        "visual",
        "accessibility",
        "performance",
        "compatibility",
        "export",
        "human"
      ]
    }
  }
}
